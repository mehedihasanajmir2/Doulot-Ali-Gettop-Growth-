rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Website configuration data - globally readable, writable by admin, but NEVER deletable (guaranteed data longevity)
    match /configs/website_data {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false; // Absolutely no deletions permitted under any circumstances
    }
    
    // Bookings data - globally readable/writable, with deletability enabled for administrative cleanups
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
    
    // Block any other unexpected collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
